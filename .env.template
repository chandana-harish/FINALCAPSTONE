# =================================================================
# AI CI/CD Failure Analyzer Platform - Local Environment Settings
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit the '.env' file containing real secrets to git.
# =================================================================

# --- Azure DevOps Configuration ---
# Your organization name (e.g. if URL is dev.azure.com/myorg, value is 'myorg')
ADO_ORG_NAME=your_organization_name
# Personal Access Token (PAT) with Build:Read and Project:Read scopes
ADO_PAT=your_personal_access_token

# --- OpenAI Configuration ---
# Your standard OpenAI API key (starts with sk-proj- or sk-)
OPENAI_API_KEY=your_standard_openai_api_key
# The model name you wish to use (default: gpt-4o)
OPENAI_MODEL_NAME=gpt-4o

# --- Azure Cosmos DB Configuration ---
# URI from the Keys section in the Cosmos DB account portal
COSMOS_URI=https://your-cosmos-account.documents.azure.com:443/
# Primary Key from the Keys section
COSMOS_KEY=your_cosmos_primary_key
# Optional: Target Database name (will be created if it doesn't exist)
COSMOS_DATABASE=FailureAnalyzerDB
# Optional: Target Container name (will be created if it doesn't exist)
COSMOS_CONTAINER=analysis_results
